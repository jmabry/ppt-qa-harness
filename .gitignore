*.log
node_modules/
package-lock.json
package.json
*.jpg
*.pdf
*.pptx
.DS_Store

# Allow baseline and final QA PPTX files only
!bakeoff/outputs/*-baseline.pptx
!bakeoff/outputs/*-qa.pptx

# Bakeoff intermediates (pass files, renders, parallel QA working dirs)
bakeoff/outputs/*-pass*.pptx
bakeoff/outputs/*-slides/
bakeoff/outputs/*-qa/
bakeoff/outputs/*.err

# Bakeoff vendored skill repos (cloned during setup)
bakeoff/.vendor/

# Personal config overrides
bakeoff/bakeoff.config.local.json
